<%- include('partials/header') %>

<div class="container">
    <!-- Page Title -->
    <h1>College Event Portal</h1>

    <!-- Welcome Message for Logged In Users -->
    <% if(typeof username !== 'undefined'){ %>
        <div class="welcome-message">
            <h3>Welcome, <%= username %>!</h3>
            <p>Browse and register for upcoming college events.</p>
        </div>
    <% } %>

    <!-- Upcoming Events Section -->
    <h2>Upcoming Events</h2>

    <!-- Display all events in a clean grid layout -->
    <% if(typeof events !== 'undefined' && events.length > 0){ %>
        <div class="events-grid">
            <% events.forEach(event => { %>
                <!-- Individual Event Card -->
                <div class="event-card">
                    <h3><%= event.name %></h3>
                    
                    <!-- Event Details Box -->
                    <div class="event-details">
                        <p><strong>Date:</strong> <%= event.date %></p>
                        <p><strong>Venue:</strong> <%= event.venue %></p>
                    </div>
                    
                    <!-- Registration Form -->
                    <form action="/register-event" method="POST" style="margin: 0;">
                        <input type="hidden" name="eventName" value="<%= event.name %>">
                        <button type="submit">Register Now</button>
                    </form>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <!-- Message when no events are available -->
        <div class="card" style="text-align: center;">
            <p>No events available at the moment. Please check back soon!</p>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>

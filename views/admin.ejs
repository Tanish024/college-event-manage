<%- include('partials/header') %>

<div class="container">
    <!-- Page Title -->
    <h2>Admin Dashboard</h2>

    <!-- Messages Section Title -->
    <h3 style="margin-top: 40px; margin-bottom: 20px;">Messages Received</h3>

    <!-- Display All Messages in Professional Cards -->
    <% if(messages && messages.length > 0) { %>
        <% messages.forEach(msg => { %>
            <!-- Individual Message Card -->
            <div class="card">
                <!-- Sender Name -->
                <h4 style="margin: 0 0 10px 0;"><%= msg.name %></h4>
                
                <!-- Sender Email -->
                <p style="margin: 5px 0; color: #666;">
                    <strong>Email:</strong> 
                    <a href="mailto:<%= msg.email %>" style="color: #1e3a5f; text-decoration: none;">
                        <%= msg.email %>
                    </a>
                </p>
                
                <!-- Message Content -->
                <p style="margin: 10px 0; line-height: 1.6; padding: 12px; background: #f8f9fa; border-radius: 4px;">
                    <%= msg.message %>
                </p>
                
                <!-- Timestamp -->
                <p style="margin: 0; font-size: 12px; color: #999;">
                    Received: <% if(msg.time) { %><%= msg.time %><% } else { %>Recently<% } %>
                </p>
            </div>
        <% }) %>
    <% } else { %>
        <!-- Message When No Messages Available -->
        <div class="card" style="text-align: center;">
            <p style="color: #666;">No messages received yet.</p>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>

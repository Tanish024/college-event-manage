<%- include('partials/header') %>

<div class="container">
    <!-- Page Title -->
    <h2>User Login</h2>

    <!-- Login Form with Professional Styling -->
    <form action="/login" method="POST">
        <!-- Email Input Field -->
        <input 
            type="email" 
            name="email" 
            placeholder="Email Address" 
            required
            autocomplete="email"
        >

        <!-- Password Input Field -->
        <input 
            type="password" 
            name="password" 
            placeholder="Password" 
            required
            autocomplete="current-password"
        >

        <!-- Submit Button -->
        <button type="submit">Log In</button>
    </form>

    <!-- Link to Sign Up Page for New Users -->
    <div style="text-align: center; margin-top: 20px;">
        <p>Don't have an account? <a href="/signup" style="color: #1e3a5f; text-decoration: none; font-weight: 600;">Sign up here</a></p>
    </div>
</div>

<%- include('partials/footer') %>

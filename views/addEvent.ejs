<%- include('partials/header') %>

<div class="container">
    <!-- Page Title -->
    <h2>Create New Event</h2>

    <!-- Event Creation Form with Professional Styling -->
    <form action="/add-event" method="POST">
        <!-- Event Title Input -->
        <input 
            type="text" 
            name="title" 
            placeholder="Event Title" 
            required
        >

        <!-- Event Date Input -->
        <input 
            type="date" 
            name="date" 
            required
        >

        <!-- Event Venue Input -->
        <input 
            type="text" 
            name="venue" 
            placeholder="Venue Location" 
            required
        >

        <!-- Submit Button -->
        <button type="submit">Create Event</button>
    </form>
</div>

<%- include('partials/footer') %>

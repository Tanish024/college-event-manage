<%- include('partials/header') %>

<div class="container">
    <!-- Page Title -->
    <h2>Contact Us</h2>

    <!-- Contact Form with Professional Styling -->
    <form action="/contact" method="POST">
        <!-- Full Name Input Field -->
        <input 
            type="text" 
            name="name" 
            placeholder="Full Name" 
            required
            autocomplete="name"
        >

        <!-- Email Input Field -->
        <input 
            type="email" 
            name="email" 
            placeholder="Email Address" 
            required
            autocomplete="email"
        >

        <!-- Message Textarea -->
        <textarea 
            name="message" 
            placeholder="Your Message" 
            required
        ></textarea>

        <!-- Submit Button -->
        <button type="submit">Send Message</button>
    </form>

    <!-- Contact Information -->
    <div class="card" style="text-align: center; max-width: 500px; margin: 30px auto;">
        <p style="color: #666;">We appreciate your message. Our team will get back to you as soon as possible.</p>
    </div>
</div>

<%- include('partials/footer') %>
